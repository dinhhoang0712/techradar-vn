# ============================================================================
# docker-compose secrets / toggles.
#
#   cp .env.docker.example .env
#   docker compose up --build
#
# Only the values below are read from .env. All service-to-service wiring
# (hostnames + bundled-datastore credentials) is hard-coded in docker-compose.yml,
# so this file cannot break inter-container connectivity.
# ============================================================================

# Spring profile. dev = applies the seed (admin@techradar.vn / Admin@12345) and
# verbose logging. Set to "prod" for no seed + WARN-level logs.
APP_ENV=dev

# JWT signing secret. Use a random value >= 256 bits in production.
JWT_SECRET=change-this-in-production-with-at-least-256-bits

# Shared secret between the Spring gateway and ai-rag-core (sent as X-Internal-Auth).
# MUST be identical on both — compose injects it into spring-api and ai-rag-core.
INTERNAL_API_TOKEN=techradar-internal-secret

# LLM for RAG chat answers. The stack boots without a key, but chat responses will
# error until one is provided. provider = "openai" | "gemini".
LLM_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=

# CORS / web.
ALLOWED_ORIGINS=*
CORS_ORIGINS=*
WEB_RESET_URL=http://localhost:5173/login

# ml-clustering: optional S3 artifacts (snapshot parquet + cluster_labels.json).
# Leave blank to run clustering purely from Neo4j / seeded data.
MLCLUSTER_S3_BUCKET=
MLCLUSTER_S3_ACCESS_KEY_ID=
MLCLUSTER_S3_SECRET_ACCESS_KEY=
