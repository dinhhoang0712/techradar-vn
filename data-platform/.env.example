# Data Platform — environment variables
# Copy to .env for local development outside Docker

KAFKA_BOOTSTRAP_SERVERS=localhost:9092

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_SECURE=false

POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/techradar

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# URL of ai-rag-core service (for triggering embed)
RAG_BASE_URL=http://localhost:8000

# Must match EMBED_SECRET in ai-rag-core .env
EMBED_SECRET=changeme

# Must match INTERNAL_API_TOKEN in docker-compose
INTERNAL_API_TOKEN=techradar-internal-secret

# Scheduler: cron expressions (Asia/Ho_Chi_Minh timezone)
# Format: "hour minute"  e.g. "2 0" = 2:00 AM
GOLD_ETL_CRON=3 0          # Run Gold ETL at 3:00 AM daily
EMBED_TRIGGER_CRON=4 0     # Trigger embed at 4:00 AM daily
